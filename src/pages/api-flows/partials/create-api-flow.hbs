<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2">
            <span id="apiFlowFormTitle">Create API Workflow</span>
            <span id="editingFlowStatusBadge" class="api-flow-status-badge d-none"></span>
        </div>
        <button type="button" class="btn-close" id="cancelApiFlowBtn" aria-label="Close"></button>
    </div>
    <div class="card-body px-4 py-4">

        {{!-- Hidden fields --}}
        <input type="hidden" id="editingApiFlowId" value="" />
        <input type="hidden" id="editingApiFlowVisibility" value="PUBLIC" />
        <input type="hidden" id="editingApiFlowAgentVisibility" value="VISIBLE" />

        {{!-- ── SECTION 1: Basic Information ── --}}
        <div class="af-section">
            <div class="af-section-header">
                <div class="af-step-badge">1</div>
                <div class="flex-grow-1">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="af-section-title">Basic Information</div>
                        <span class="af-section-summary d-none" id="af-summary-1"></span>
                    </div>
                    <div class="af-section-subtitle">Name, describe, and configure visibility for your API workflow</div>
                </div>
                <button type="button" class="af-collapse-btn" data-af-collapse aria-label="Toggle section">
                    <i class="bi bi-chevron-up"></i>
                </button>
            </div>
            <div class="af-section-body">

                <div class="mb-3">
                    <label for="apiFlowName" class="form-label fw-semibold">
                        Name <span class="text-danger">*</span>
                    </label>
                    <input type="text" class="form-control" id="apiFlowName"
                        placeholder="e.g. User Onboarding Flow" maxlength="120" />
                    <div class="invalid-feedback">Name is required.</div>
                </div>

                <div class="mb-4">
                    <label for="apiFlowDescription" class="form-label fw-semibold">
                        Description <span class="text-danger">*</span>
                    </label>
                    <textarea class="form-control" id="apiFlowDescription" rows="4"
                        placeholder="e.g. Orchestrates a multi-step patient booking workflow across appointment scheduling and healthcare provider systems…"></textarea>
                    <div class="invalid-feedback">Description is required.</div>
                    <div class="form-text mt-1">
                        <i class="bi bi-lightbulb me-1"></i>
                        Describe the use case clearly — this trains AI agents to recommend this workflow for similar scenarios.
                    </div>
                </div>

                <hr class="af-section-divider" />

                <div class="mb-3">
                    <label class="form-label fw-semibold mb-1 d-block">Portal Visibility</label>
                    <div class="af-seg" role="radiogroup" aria-label="Portal visibility">
                        <input type="radio" class="btn-check" name="apiFlowVisibility" id="visibilityPublic"
                            value="PUBLIC" autocomplete="off" checked />
                        <label class="af-seg-option" for="visibilityPublic">
                            <i class="bi bi-globe af-seg-icon"></i>
                            <div class="af-seg-label">
                                <span class="af-seg-name">Public</span>
                                <span class="af-seg-sub">Anyone on portal</span>
                            </div>
                            <i class="bi bi-check2 af-seg-check"></i>
                        </label>
                        <input type="radio" class="btn-check" name="apiFlowVisibility" id="visibilityPrivate"
                            value="PRIVATE" autocomplete="off" />
                        <label class="af-seg-option" for="visibilityPrivate">
                            <i class="bi bi-lock af-seg-icon"></i>
                            <div class="af-seg-label">
                                <span class="af-seg-name">Private</span>
                                <span class="af-seg-sub">Restricted access</span>
                            </div>
                            <i class="bi bi-check2 af-seg-check"></i>
                        </label>
                    </div>
                </div>

                <div class="mb-1">
                    <label class="form-label fw-semibold mb-1 d-block">Agent Visibility</label>
                    <div class="af-seg" role="radiogroup" aria-label="Agent visibility">
                        <input type="radio" class="btn-check" name="apiFlowAgentVisibility" id="agentVisibilityVisible"
                            value="VISIBLE" autocomplete="off" checked />
                        <label class="af-seg-option" for="agentVisibilityVisible">
                            <i class="bi bi-robot af-seg-icon"></i>
                            <div class="af-seg-label">
                                <span class="af-seg-name">Visible to Agents</span>
                                <span class="af-seg-sub">Agents can discover</span>
                            </div>
                            <i class="bi bi-check2 af-seg-check"></i>
                        </label>
                        <input type="radio" class="btn-check" name="apiFlowAgentVisibility" id="agentVisibilityHidden"
                            value="HIDDEN" autocomplete="off" />
                        <label class="af-seg-option" for="agentVisibilityHidden">
                            <i class="bi bi-eye-slash af-seg-icon"></i>
                            <div class="af-seg-label">
                                <span class="af-seg-name">Hidden from Agents</span>
                                <span class="af-seg-sub">Excluded from discovery</span>
                            </div>
                            <i class="bi bi-check2 af-seg-check"></i>
                        </label>
                    </div>
                </div>

            </div>
        </div>

        {{!-- ── SECTION 2: API Workflow ── --}}
        <div class="af-section">
            <div class="af-section-header">
                <div class="af-step-badge">2</div>
                <div class="flex-grow-1">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="af-section-title">API Workflow</div>
                        <span class="af-section-summary d-none" id="af-summary-2"></span>
                    </div>
                    <div class="af-section-subtitle">Define your API workflow as a structured Arazzo spec or as natural language instructions for AI agents</div>
                </div>
                <button type="button" class="af-collapse-btn" data-af-collapse aria-label="Toggle section">
                    <i class="bi bi-chevron-up"></i>
                </button>
            </div>
            <div class="af-section-body">

                {{!-- Path Chooser --}}
                <div class="af-path-chooser mb-4">
                    <div class="af-path-card af-path-card--active" id="pathUploadCard" data-path="upload"
                        role="button" tabindex="0" aria-pressed="true">
                        <div class="af-path-card-icon-wrap">
                            <i class="bi bi-cloud-upload-fill af-path-card-icon"></i>
                        </div>
                        <div class="af-path-card-content">
                            <div class="af-path-card-title">Upload API Workflow Definition</div>
                            <div class="af-path-card-desc">Drop in a <code>.yaml</code>, <code>.yml</code>, or <code>.json</code> Arazzo spec — source descriptions are automatically validated</div>
                        </div>
                        <i class="bi bi-check-circle-fill af-path-card-check" aria-hidden="true"></i>
                    </div>
                    <div class="af-path-card" id="pathCreateCard" data-path="create"
                        role="button" tabindex="0" aria-pressed="false">
                        <div class="af-path-card-icon-wrap">
                            <i class="bi bi-stars af-path-card-icon"></i>
                        </div>
                        <div class="af-path-card-content">
                            <div class="af-path-card-title">Create from Template</div>
                            <div class="af-path-card-desc">Select APIs, generate a starter template, then refine it with Claude or edit visually in VS Code</div>
                        </div>
                        <i class="bi bi-check-circle-fill af-path-card-check" aria-hidden="true"></i>
                    </div>
                </div>

                {{!-- ══ UPLOAD PATH ══ --}}
                <div id="uploadPathContent">

                    {{!-- Drag-drop Zone --}}
                    <div class="af-upload-zone" id="arazzoDropZone"
                        role="button" tabindex="0" aria-label="Workflow file upload area — click or drag a file here">
                        <div class="af-upload-zone-inner">
                            <i class="bi bi-file-earmark-arrow-up af-upload-zone-icon" aria-hidden="true"></i>
                            <div class="af-upload-zone-title">Drop your workflow file here</div>
                            <div class="af-upload-zone-sub">
                                <span class="af-upload-format-hint">
                                    <span class="af-upload-format-pill af-upload-format-pill--arazzo">Arazzo</span>
                                    <code>.yaml</code> · <code>.yml</code> · <code>.json</code>
                                </span>
                                <span class="af-upload-format-sep">or</span>
                                <span class="af-upload-format-hint">
                                    <span class="af-upload-format-pill af-upload-format-pill--md">Markdown</span>
                                    <code>.md</code>
                                </span>
                                &emsp;
                                <button type="button" class="af-upload-browse-btn" id="uploadBrowseBtn">browse files</button>
                            </div>
                        </div>
                    </div>

                    {{!-- Post-upload: file strip + per-format detail panel --}}
                    <div id="uploadValidationPanel" class="d-none mt-3">

                        <div class="af-upload-file-strip" id="uploadFileStrip">
                            <i class="bi bi-file-earmark-check-fill af-upload-file-strip-icon" aria-hidden="true"></i>
                            <span class="af-upload-file-name" id="uploadFileName"></span>
                            <span class="af-upload-type-badge" id="uploadTypeBadge"></span>
                            <button type="button" class="af-upload-file-remove" id="removeUploadBtn"
                                title="Remove file and upload a different one" aria-label="Remove uploaded file">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>

                        {{!-- Arazzo: source description validation --}}
                        <div class="af-sd-validation mt-2 d-none" id="sdValidationContainer">
                            <div class="af-sd-validation-header">
                                <i class="bi bi-link-45deg me-1" aria-hidden="true"></i>Source Descriptions
                                <span class="af-sd-validation-hint" id="sdValidationHint"></span>
                            </div>
                            <div id="sdValidationItems"></div>
                        </div>

                        {{!-- Markdown: summary strip --}}
                        <div class="af-md-summary mt-2 d-none" id="mdSummaryPanel">
                            <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
                            <span id="mdSummaryText"></span>
                        </div>

                    </div>

                    <input type="file" id="arazoFileInput" accept=".yaml,.yml,.json,.md" style="display:none" aria-hidden="true" />
                </div>

                {{!-- ══ CREATE FROM TEMPLATE PATH ══ --}}
                <div id="createPathContent" class="d-none">

                    {{!-- API Selection --}}
                    {{#if orgAPIs.length}}

                    <div class="mb-1">
                        <div class="fw-semibold small">Select APIs for this workflow</div>
                        <div class="text-muted small mt-1 mb-3">
                            Choose APIs that participate in this flow — their specs drive the generated Arazzo template
                        </div>
                    </div>

                    {{!-- Hidden checkboxes — source of truth for selection --}}
                    <div style="display:none;" id="apiCheckboxStore">
                        {{#each orgAPIs}}
                        <input type="checkbox" class="api-flow-api-checkbox"
                            value="{{this.apiId}}"
                            data-api-name="{{this.apiName}}"
                            data-api-handle="{{this.apiHandle}}"
                            data-api-description="{{this.apiDescription}}"
                            data-api-type="{{this.apiType}}"
                            data-production-url="{{this.productionUrl}}"
                            data-agent-visibility="{{this.agentVisibility}}" />
                        {{/each}}
                    </div>

                    <div class="af-api-chips-row mb-3" id="apiSelectedChips">
                        <span class="text-muted small fst-italic">No APIs selected</span>
                    </div>

                    <div class="mb-3">
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0">
                                <i class="bi bi-search text-muted" style="font-size: 0.85rem;"></i>
                            </span>
                            <input type="text" class="form-control border-start-0 border-end-0" id="apiCardSearch"
                                placeholder="Filter APIs by name, type, or description…" autocomplete="off" />
                            <button type="button" class="btn btn-sm common-btn-outlined af-show-selected-btn" id="showSelectedOnlyBtn"
                                title="Show selected APIs only">
                                <i class="bi bi-funnel me-1"></i> Selected only
                            </button>
                        </div>
                    </div>

                    <div class="af-api-grid mb-2" id="apiCardGrid"></div>

                    <div class="mb-4 mt-1">
                        <span id="apiSelectedCount" class="text-muted small"></span>
                    </div>

                    {{else}}
                    <div class="text-muted small fst-italic border rounded p-3 mb-4">
                        No APIs found in this organization. <a href="apis">Add APIs</a> first.
                    </div>
                    {{/if}}

                    {{!-- Format Toggle --}}
                    <div class="af-create-format-toggle mb-3" role="group" aria-label="Workflow format">
                        <button type="button" class="af-create-format-btn af-create-format-btn--active"
                            id="createFormatArazzo" data-format="arazzo">
                            <i class="bi bi-code-slash" aria-hidden="true"></i> Arazzo Spec
                        </button>
                        <button type="button" class="af-create-format-btn"
                            id="createFormatMarkdown" data-format="markdown">
                            <i class="bi bi-markdown" aria-hidden="true"></i> Markdown
                        </button>
                    </div>

                    {{!-- Action Buttons --}}
                    <div class="af-create-actions mb-4">
                        <button type="button" class="af-generate-claude-btn" id="generateWithClaudeBtn">
                            <svg class="af-btn-icon" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="Claude">
                                <path fill="currentColor" d="m4.7144 15.9555 4.7174-2.6471.079-.2307-.079-.1275h-.2307l-.7893-.0486-2.6956-.0729-2.3375-.0971-2.2646-.1214-.5707-.1215-.5343-.7042.0546-.3522.4797-.3218.686.0608 1.5179.1032 2.2767.1578 1.6514.0972 2.4468.255h.3886l.0546-.1579-.1336-.0971-.1032-.0972L6.973 9.8356l-2.55-1.6879-1.3356-.9714-.7225-.4918-.3643-.4614-.1578-1.0078.6557-.7225.8803.0607.2246.0607.8925.686 1.9064 1.4754 2.4893 1.8336.3643.3035.1457-.1032.0182-.0728-.164-.2733-1.3539-2.4467-1.445-2.4893-.6435-1.032-.17-.6194c-.0607-.255-.1032-.4674-.1032-.7285L6.287.1335 6.6997 0l.9957.1336.419.3642.6192 1.4147 1.0018 2.2282 1.5543 3.0296.4553.8985.2429.8318.091.255h.1579v-.1457l.1275-1.706.2368-2.0947.2307-2.6957.0789-.7589.3764-.9107.7468-.4918.5828.2793.4797.686-.0668.4433-.2853 1.8517-.5586 2.9021-.3643 1.9429h.2125l.2429-.2429.9835-1.3053 1.6514-2.0643.7286-.8196.85-.9046.5464-.4311h1.0321l.759 1.1293-.34 1.1657-1.0625 1.3478-.8804 1.1414-1.2628 1.7-.7893 1.36.0729.1093.1882-.0183 2.8535-.607 1.5421-.2794 1.8396-.3157.8318.3886.091.3946-.3278.8075-1.967.4857-2.3072.4614-3.4364.8136-.0425.0304.0486.0607 1.5482.1457.6618.0364h1.621l3.0175.2247.7892.522.4736.6376-.079.4857-1.2142.6193-1.6393-.3886-3.825-.9107-1.3113-.3279h-.1822v.1093l1.0929 1.0686 2.0035 1.8092 2.5075 2.3314.1275.5768-.3218.4554-.34-.0486-2.2039-1.6575-.85-.7468-1.9246-1.621h-.1275v.17l.4432.6496 2.3436 3.5214.1214 1.0807-.17.3521-.6071.2125-.6679-.1214-1.3721-1.9246L14.38 17.959l-1.1414-1.9428-.1397.079-.674 7.2552-.3156.3703-.7286.2793-.6071-.4614-.3218-.7468.3218-1.4753.3886-1.9246.3157-1.53.2853-1.9004.17-.6314-.0121-.0425-.1397.0182-1.4328 1.9672-2.1796 2.9446-1.7243 1.8456-.4128.164-.7164-.3704.0667-.6618.4008-.5889 2.386-3.0357 1.4389-1.882.929-1.0868-.0062-.1579h-.0546l-6.3385 4.1164-1.1293.1457-.4857-.4554.0608-.7467.2307-.2429 1.9064-1.3114Z"/>
                            </svg>
                            Generate with Claude
                        </button>
                        <button type="button" class="af-generate-chatgpt-btn" id="generateWithChatGPTBtn">
                            <svg class="af-btn-icon" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="ChatGPT">
                                <path fill="currentColor" d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.896zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/>
                            </svg>
                            Generate with ChatGPT
                        </button>
                        <button type="button" class="af-vscode-btn" id="openInVSCodeBtn">
                            <svg class="af-btn-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M23.15 2.587L18.21.21a1.494 1.494 0 00-1.705.29l-9.46 8.63-4.12-3.128a.999.999 0 00-1.276.057L.327 7.261A1 1 0 00.326 8.74L3.9 12 .326 15.26a1 1 0 00.001 1.479L1.65 17.94a.999.999 0 001.276.057l4.12-3.128 9.46 8.63a1.492 1.492 0 001.704.29l4.942-2.377A1.5 1.5 0 0024 19.06V4.94a1.5 1.5 0 00-.85-1.353zm-5.146 14.861L10.826 12l7.178-5.448v10.896z" fill="currentColor"/>
                            </svg>
                            Open in VS Code
                        </button>
                    </div>

                </div>{{!-- end createPathContent --}}

                {{!-- Arazzo Spec Editor --}}
                <div id="apiFlowDefinitionWrapper" class="d-none">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="form-label fw-semibold mb-0 d-flex align-items-center gap-2">
                            Arazzo Specification <span class="text-danger">*</span>
                            <span class="af-info-tip" aria-label="Tip about sourceDescription name">
                                <i class="bi bi-info-circle" aria-hidden="true"></i>
                                <span class="af-info-tip-content" role="tooltip">
                                    The <code>name</code> in each <code>sourceDescription</code> is how users and agents identify which API is being called — use a clear, descriptive identifier.
                                </span>
                            </span>
                        </label>
                        <button type="button" class="common-btn-outlined" id="copyArazzoBtn"
                            title="Copy spec to clipboard">
                            <i class="bi bi-clipboard me-1"></i> Copy
                        </button>
                    </div>
                    <div id="arazoEditorHost" class="af-cm-host"></div>
                    <textarea id="apiFlowDefinition" style="display:none;"
                        placeholder="arazzo: '1.0.0'&#10;info:&#10;  title: My Flow&#10;  version: 1.0.0&#10;workflows:&#10;  - workflowId: my-flow&#10;    steps: []"></textarea>
                    <div id="apiFlowDefinitionInvalid" class="invalid-feedback" style="display:none;">Arazzo Specification is required.</div>
                    <div class="form-text mt-1">
                        <i class="bi bi-info-circle me-1"></i>
                        YAML or JSON · Arazzo 1.0.0 · Stored alongside the agent prompt
                    </div>
                </div>

                {{!-- Markdown Content Editor --}}
                <div id="markdownContentWrapper" class="d-none">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label for="markdownContent" class="form-label fw-semibold mb-0">
                            Workflow Description <span class="text-danger">*</span>
                        </label>
                        <button type="button" class="common-btn-outlined" id="copyMarkdownBtn"
                            title="Copy to clipboard">
                            <i class="bi bi-clipboard me-1"></i> Copy
                        </button>
                    </div>
                    <textarea class="form-control af-md-editor" id="markdownContent" rows="16"
                        placeholder="# My Workflow&#10;&#10;Describe what this workflow does in plain language…&#10;&#10;## Steps&#10;1. Call the authentication API with the user credentials&#10;2. Use the returned token to fetch the user profile…"></textarea>
                    <div class="invalid-feedback">Workflow description is required.</div>
                    <div class="d-flex justify-content-between align-items-center mt-1">
                        <div class="form-text">
                            <i class="bi bi-markdown me-1"></i>
                            Markdown supported · Describe the workflow in natural language
                        </div>
                        <span class="af-md-word-count" id="mdWordCount"></span>
                    </div>
                </div>

            </div>
        </div>

        {{!-- ── SECTION 3: Agent Prompt ── --}}
        <div class="af-section af-section--last">
            <div class="af-section-header">
                <div class="af-step-badge">3</div>
                <div class="flex-grow-1">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="af-section-title">
                            <i class="bi bi-eye-slash af-agent-hidden-icon d-none" id="tabVisualHiddenIcon" aria-hidden="true"></i>
                            Agent Prompt
                        </div>
                        <span class="af-section-summary d-none" id="af-summary-3"></span>
                    </div>
                    <div class="af-section-subtitle">Auto-generated prompt that guides AI agents in executing this workflow</div>
                </div>
                <button type="button" class="af-collapse-btn" data-af-collapse aria-label="Toggle section">
                    <i class="bi bi-chevron-up"></i>
                </button>
            </div>
            <div class="af-section-body">

                {{!-- Hidden-from-agents warning --}}
                <div class="af-agent-hidden-banner d-none" id="agentHiddenBanner" role="status" aria-live="polite">
                    <div class="af-agent-hidden-banner-body">
                        <i class="bi bi-exclamation-triangle-fill af-agent-hidden-banner-icon" aria-hidden="true"></i>
                        <div class="af-agent-hidden-banner-text">
                            <strong>This flow is hidden from agents.</strong>
                            <span>Agents won't use this prompt until you change Agent Visibility to Visible.</span>
                        </div>
                        <button type="button" class="af-agent-hidden-banner-action" id="changeVisibilityBtn">
                            Change visibility <i class="bi bi-arrow-right" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-start mb-3">
                    <p class="text-muted small mb-0 mt-1">
                        Fully customizable — regenerate any time you change API workflow name or description.
                    </p>
                    <div class="d-flex gap-2 flex-shrink-0 ms-3">
                        <button type="button" class="common-btn-primary" id="regeneratePromptBtn"
                            title="Generate agent prompt from selected APIs and description">
                            <i class="bi bi-magic me-1"></i> Generate Prompt for Agents
                        </button>
                        <button type="button" class="common-btn-outlined" id="copyFieldPromptBtn"
                            title="Copy to clipboard">
                            <i class="bi bi-clipboard"></i>
                        </button>
                    </div>
                </div>
                <textarea class="form-control api-flow-prompt-editor" id="agentPromptField" rows="14"
                    placeholder="Click 'Generate Prompt for Agents' to create your agent prompt, or write one manually…"></textarea>
                <div class="invalid-feedback">Agent prompt is required.</div>

            </div>
        </div>

        {{!-- ── Sticky form actions ── --}}
        <div class="af-form-actions-sticky">
            <button type="button" class="common-btn-outlined" id="cancelApiFlowBtn2">Cancel</button>
            <div class="btn-group" id="saveApiFlowGroup">
                <button type="button" class="common-btn-primary af-save-main" id="saveApiFlowBtn" data-status="PUBLISHED">
                    <i class="bi bi-send me-1"></i> Publish Flow
                </button>
                <button type="button"
                    class="common-btn-primary af-save-toggle dropdown-toggle dropdown-toggle-split"
                    data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="visually-hidden">More save options</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end af-save-dropdown">
                    <li>
                        <button type="button" class="dropdown-item af-save-dropdown-item" id="saveDraftBtn" data-status="DRAFT">
                            <i class="bi bi-file-earmark-text me-2"></i>
                            <span class="fw-semibold">Save as Draft</span>
                            <div class="af-save-dropdown-hint">Save without making it visible to consumers</div>
                        </button>
                    </li>
                </ul>
            </div>
        </div>

    </div>
</div>
