<script>
    var apiFlowsData = {{{ json apiFlows }}} || [];
    var currentOrgID = '{{orgID}}';
    var currentViewName = '{{viewName}}';
</script>

<section id="apiFlowSection">

    {{!-- ── LIST VIEW ── --}}
    <div id="apiFlowList">
        <div class="mb-3">
            <a href="{{baseUrl}}/" class="d-inline-flex align-items-center text-muted"
                style="text-decoration: none; font-size: 14px;">
                <i class="fas fa-arrow-left me-2"></i>Home
            </a>
        </div>
        <!-- Header -->
        <div class="api-flows-header mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <div class="p-1">
                    <div class="container-header mb-4 d-sm-flex justify-content-between align-items-center">
                        <span>API Workflows</span>
                    </div>
                    <p class="text-muted mb-2"> Encode your real-world API use cases as guided workflows — so AI agents
                        know exactly how your
                        APIs work together, in the right order, for the right purpose. No guesswork, no hallucinations.</p>
                </div>
                {{#if apiFlows.length}}
                <button type="button" class="common-btn-primary text-nowrap flex-shrink-0" id="createApiFlowBtn">
                    <i class="bi bi-plus-circle me-1"></i> Create
                </button>
                {{/if}}
            </div>
        </div>

        {{#if apiFlows.length}}
        <!-- Flows Grid -->
        <div class="api-flows-grid">
            {{#each apiFlows}}
            <div class="api-flow-card">
                <div class="api-flow-card-header">
                    <div class="api-flow-card-title-section">
                        <h6 class="api-flow-card-title">{{this.name}}</h6>
                        <span class="api-flow-status-badge api-flow-status-{{lowercase this.status}}">
                            {{this.status}}
                        </span>
                    </div>
                </div>
                <div class="api-flow-card-body">
                    <p class="api-flow-card-description" title="{{this.description}}">
                        {{this.description}}
                    </p>
                </div>
                <div class="api-flow-card-footer">
                    <div class="api-flow-card-actions">
                        <button type="button" class="api-flow-action-btn" title="View agent prompt"
                            onclick="openPromptModal('{{this.apiFlowId}}')"
                            aria-label="View agent prompt for {{this.name}}">
                            <i class="bi bi-robot"></i>
                        </button>
                        <button type="button" class="api-flow-action-btn" title="Edit"
                            onclick="openEditApiFlow('{{this.apiFlowId}}')" aria-label="Edit {{this.name}}">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button type="button" class="api-flow-action-btn api-flow-action-btn--danger" title="Delete"
                            onclick="openDeleteApiFlowModal('{{@root.orgID}}', '{{@root.viewName}}', '{{this.apiFlowId}}', '{{this.name}}')"
                            aria-label="Delete {{this.name}}">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
        {{else}}
        <div class="api-flow-empty-state">
            <div class="api-flow-empty-state-content">
                <i class="bi bi-diagram-3"></i>
                <p class="mt-3 mb-1 fw-semibold">No API Workflows yet</p>
                <p class="text-muted small mt-1">Create your first flow to define a multi-step API sequence.</p>
                <button type="button" class="common-btn-primary mt-3" id="createApiFlowBtnEmpty">
                    <i class="bi bi-plus-circle me-1"></i> Create Your First Workflow
                </button>
            </div>
        </div>
        {{/if}}
    </div>

    {{!-- ── CREATE / EDIT PANEL ── --}}
    <div id="apiFlowForm" style="display:none;">
        {{> create-api-flow}}
    </div>

</section>

{{!-- ── DELETE CONFIRMATION MODAL ── --}}
<div class="modal fade" id="deleteApiFlowModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteApiFlowModalTitle"></h5>
            </div>
            <div class="modal-body">
                <p id="deleteApiFlowModalMessage"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn common-btn-link" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn common-btn-primary common-btn-danger" id="deleteApiFlowConfirmBtn" data-cyid="confirm">
                    Confirm
                </button>
            </div>
        </div>
    </div>
</div>

{{!-- ── AGENT PROMPT MODAL ── --}}
<div class="modal fade" id="agentPromptModal" tabindex="-1" aria-labelledby="agentPromptModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title mb-0" id="agentPromptModalLabel">Agent Prompt</h5>
                    <small class="text-muted" id="agentPromptFlowName"></small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="api-flow-prompt-toolbar">
                    <span class="small text-muted">Use this prompt with an AI agent.</span>
                    <button type="button" class="common-btn-outlined" id="copyPromptBtn" onclick="copyPrompt()">
                        <i class="bi bi-clipboard me-1"></i> Copy
                    </button>
                </div>
                <pre id="agentPromptContent" class="api-flow-prompt-pre"></pre>
            </div>
        </div>
    </div>
</div>