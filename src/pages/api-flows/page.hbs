<head>
    <link rel="stylesheet" href="/technical-styles/api-flows.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/yaml/yaml.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/js-yaml/4.1.0/js-yaml.min.js"></script>
    <script src='/technical-scripts/api-flows.js' defer></script>
</head>

{{> header profile=profile baseUrl=baseUrl showApiWorkflowsNav=showApiWorkflowsNav}}
{{> sidebar profile=profile baseUrl=baseUrl devportalMode=devportalMode showApiWorkflowsNav=showApiWorkflowsNav}}

<div class="container mt-4 mb-4">
    <div class="mb-3">
        <a href="{{baseUrl}}/" class="d-inline-flex align-items-center text-muted"
            style="text-decoration: none; font-size: 14px;">
            <i class="fas fa-arrow-left me-2"></i>Home
        </a>
    </div>
    <ul class="nav configure-tabs mb-4" id="viewConfigureTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="llms-tab-btn" data-bs-toggle="tab"
                data-bs-target="#llmsTabContent" type="button" role="tab"
                aria-selected="true" aria-controls="llmsTabContent">
                <i class="bi bi-robot me-2"></i>LLM Instructions
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="workflows-tab-btn" data-bs-toggle="tab"
                data-bs-target="#workflowsTabContent" type="button" role="tab"
                aria-selected="false" aria-controls="workflowsTabContent">
                <i class="bi bi-diagram-3 me-2"></i>API Workflows
            </button>
        </li>
    </ul>
    <div class="tab-content" id="viewConfigureTabContent">
        <div class="tab-pane fade show active" id="llmsTabContent" role="tabpanel" aria-labelledby="llms-tab-btn">
            {{> llms-config}}
        </div>
        <div class="tab-pane fade" id="workflowsTabContent" role="tabpanel" aria-labelledby="workflows-tab-btn">
            {{> api-flows}}
        </div>
    </div>
</div>

{{> alert}}
