<head>
    <link rel="stylesheet" href="/technical-styles/agent-prompt.css">
    <link rel="stylesheet" href="/technical-styles/api-workflows.css">
    {{#unless (eq flow.contentType "MD")}}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@jentic/arazzo-ui@1.0.0-alpha.30/dist/arazzo-ui.css" integrity="sha256-WHPlCD3ecWnrluuPAx7VypEZtfvv4DrIMfdLYzLshsM=" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/@jentic/arazzo-ui@1.0.0-alpha.30/dist/arazzo-ui.js" integrity="sha256-OYzURPQLK+lup5rGo+IQmVbjWOjVgjURBWDDtMHIOaw=" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/js-yaml@4.1.0/dist/js-yaml.min.js" integrity="sha256-Rdw90D3AegZwWiwpibjH9wkBPwS9U4bjJ51ORH8H69c=" crossorigin="anonymous"></script>
    {{/unless}}
    {{#if (eq flow.contentType "MD")}}
    <script src="https://cdn.jsdelivr.net/npm/marked@13.0.3/marked.min.js" integrity="sha256-Wt6n2O5BpwD8zBS7nVAxBPBHDMF6hK0+Fn0/UlHq4No=" crossorigin="anonymous"></script>
    {{/if}}
</head>

<main data-flow-handle="{{flow.handle}}" data-flow-content-type="{{flow.contentType}}">
    {{> header profile=profile baseUrl=baseUrl devportalMode=devportalMode showApiWorkflowsNav=showApiWorkflowsNav}}
    {{> sidebar profile=profile baseUrl=baseUrl devportalMode=devportalMode showApiWorkflowsNav=showApiWorkflowsNav}}

    <div class="flow-detail-section">
        {{!-- Back Button --}}
        <a href="{{baseUrl}}/api-workflows" class="flow-detail-back">
            <i class="bi bi-arrow-left"></i>
            Back
        </a>

        {{!-- Header --}}
        <div class="flow-detail-header">
            <div class="flow-detail-header-content">
                <h1>{{flow.name}}</h1>
                <p>{{flow.description}}</p>
            </div>
            <div class="flow-header-actions">
                {{#unless (eq flow.agentVisibility "HIDDEN")}}
                <button class="btn-prompt" id="openPromptBtn" data-bs-toggle="modal" data-bs-target="#agentPromptModal">
                    <i class="bi bi-file-code"></i>
                    Agent Prompt
                </button>
                {{/unless}}
            </div>
        </div>

        {{!-- Content --}}
        <div class="flow-detail-content">
            {{#if (eq flow.contentType "MD")}}
            {{!-- Markdown Preview --}}
            <div class="af-md-detail-container" id="markdownViewer"></div>
            {{else}}
            {{!-- Arazzo UI Viewer --}}
            <div class="arazzo-viewer-container">
                <div id="arazzoViewer"></div>
            </div>
            {{/if}}
        </div>
    </div>

    {{> alert}}

    {{!-- ── AGENT PROMPT MODAL ── --}}
    <div class="modal fade" id="agentPromptModal" tabindex="-1" aria-labelledby="agentPromptModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title mb-0" id="agentPromptModalLabel">Agent Prompt</h5>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="api-flow-prompt-toolbar">
                        <span class="small text-muted">Use this prompt to let your AI agent execute the workflow—handling API calls, dependencies, and errors automatically</span>
                        <div class="prompt-modal-toolbar">
                            <button type="button" class="prompt-tool-btn" id="btnDownloadPrompt" title="Download as .txt">
                                <i class="bi bi-download"></i>
                            </button>
                            <button type="button" class="prompt-tool-btn" id="btnCopyPrompt" title="Copy prompt">
                                <i class="bi bi-copy"></i>
                            </button>
                            <button type="button" class="btn-run-prompt" id="btnRunClaude">
                                <i class="bi bi-play-fill"></i> Run in Claude
                            </button>
                        </div>
                    </div>
                    <pre id="modalAgentPromptText" class="api-flow-prompt-pre">{{flow.agentPrompt}}</pre>
                </div>
            </div>
        </div>
    </div>

    {{!-- Hidden container for spec content --}}
    <textarea id="specContent" style="display: none;">{{flow.content}}</textarea>
</main>
<script src='/technical-scripts/api-flow-detail.js' defer></script>
