<head>
    <link rel="stylesheet" href="/technical-styles/api-workflows.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@jentic/arazzo-ui@latest/dist/arazzo-ui.css">
    <script src="https://cdn.jsdelivr.net/npm/@jentic/arazzo-ui@latest/dist/arazzo-ui.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/js-yaml@4.1.0/dist/js-yaml.min.js"></script>
</head>

<main>
    {{> header profile=profile baseUrl=baseUrl devportalMode=devportalMode}}
    {{> sidebar profile=profile baseUrl=baseUrl devportalMode=devportalMode}}

    <div class="flow-detail-section">
        {{!-- Back Button --}}
        <a href="{{baseUrl}}/api-workflows" class="flow-detail-back">
            <i class="bi bi-arrow-left"></i>
            Back
        </a>

        {{!-- Header --}}
        <div class="flow-detail-header">
            <div class="flow-detail-header-content">
                <h1>{{flow.name}}</h1>
                <p>{{flow.description}}</p>
            </div>
            <div class="flow-header-actions">
                {{#if (eq flow.agentVisibility "HIDDEN")}}
                <span class="flow-visibility-badge flow-agent-hidden"
                    title="Not accessible to AI agents">
                    <i class="bi bi-shield-slash"></i> AI Restricted
                </span>
                {{else}}
                <button class="btn-prompt" id="openPromptBtn">
                    <i class="bi bi-file-code"></i>
                    Agent Prompt
                </button>
                {{/if}}
            </div>
        </div>

        {{!-- Content --}}
        <div class="flow-detail-content">
            {{!-- Arazzo UI Viewer --}}
            <div class="arazzo-viewer-container">
                <div id="arazzoViewer"></div>
            </div>
        </div>
    </div>

    {{> alert}}

    {{!-- Agent Prompt Modal --}}
    <div class="modal-overlay" id="agentPromptModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Agent Prompt</h2>
                <div class="modal-header-actions">
                    <button class="modal-close" id="closePromptBtnHeader">&times;</button>
                </div>
            </div>
            <div class="modal-body">
                <p>Use this prompt to let your AI agent execute the workflow—handling API calls, dependencies, and errors automatically</p>
                <div class="modal-prompt-box">
                    <button class="modal-prompt-copy-btn" data-flow-name="{{flow.name}}"
                        title="Copy prompt to clipboard" aria-label="Copy prompt">
                        <i class="bi bi-clipboard"></i>
                        <span>Copy</span>
                    </button>
                    <pre id="modalAgentPromptText">{{flow.agentPrompt}}</pre>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-modal-close" id="closePromptBtnFooter">Close</button>
            </div>
        </div>
    </div>

    {{!-- Hidden container for spec content --}}
    <textarea id="specContent" style="display: none;">{{flow.content}}</textarea>
</main>

<script>
function openAgentPromptModal() {
    const modal = document.getElementById('agentPromptModal');
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

function closeAgentPromptModal() {
    const modal = document.getElementById('agentPromptModal');
    modal.classList.remove('show');
    document.body.style.overflow = 'auto';
}

// Close modal when clicking on overlay
document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('agentPromptModal');
    if (modal) {
        modal.addEventListener('click', function(event) {
            if (event.target === modal) {
                closeAgentPromptModal();
            }
        });
    }

    // Handle open prompt button
    const openPromptBtn = document.getElementById('openPromptBtn');
    if (openPromptBtn) {
        openPromptBtn.addEventListener('click', openAgentPromptModal);
    }

    // Handle close prompt buttons
    const closePromptBtnHeader = document.getElementById('closePromptBtnHeader');
    if (closePromptBtnHeader) {
        closePromptBtnHeader.addEventListener('click', closeAgentPromptModal);
    }

    const closePromptBtnFooter = document.getElementById('closePromptBtnFooter');
    if (closePromptBtnFooter) {
        closePromptBtnFooter.addEventListener('click', closeAgentPromptModal);
    }

    // Handle copy button click
    const copyBtn = document.querySelector('.modal-prompt-copy-btn');
    if (copyBtn) {
        copyBtn.addEventListener('click', function(event) {
            event.preventDefault();
            const flowName = this.dataset.flowName;
            copyPromptFromModal(flowName);
        });
    }
});

// Close modal with escape key
document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
        closeAgentPromptModal();
    }
});

function copyPromptFromModal(flowName) {
    const promptText = document.getElementById('modalAgentPromptText').textContent;
    navigator.clipboard.writeText(promptText).then(() => {
        showNotification(`Prompt for "${flowName}" copied!`, 'success');
    }).catch(() => {
        showNotification('Failed to copy prompt', 'error');
    });
}

function showNotification(message, type = 'info') {
    const notification = document.createElement('div');
    notification.className = `notification notification-${type}`;

    const content = document.createElement('div');
    content.className = 'notification-content';

    const icon = document.createElement('i');
    const iconClass = type === 'success' ? 'check-circle' : 'exclamation-circle';
    icon.className = `bi bi-${iconClass}`;

    const messageSpan = document.createElement('span');
    messageSpan.textContent = message;

    content.appendChild(icon);
    content.appendChild(messageSpan);
    notification.appendChild(content);
    document.body.appendChild(notification);

    setTimeout(() => {
        notification.classList.add('show');
    }, 10);

    setTimeout(() => {
        notification.classList.remove('show');
        setTimeout(() => {
            notification.remove();
        }, 300);
    }, 3000);
}

// Initialize Arazzo UI Component
document.addEventListener('DOMContentLoaded', function() {
    try {
        const specContent = document.getElementById('specContent').value.trim();
        const viewerContainer = document.getElementById('arazzoViewer');

        if (!specContent) {
            viewerContainer.innerHTML = '<p style="padding: 2rem; text-align: center; color: #999;">No specification content available</p>';
            return;
        }

        console.log('Initializing Arazzo UI component...');
        console.log('ArazzoUI available:', typeof window.ArazzoUI);

        // Initialize Arazzo UI with the spec content
        // The component accepts inline YAML/JSON strings
        if (window.ArazzoUI) {
            console.log('Starting Arazzo UI initialization...');
            console.log('Container element:', document.getElementById('arazzoViewer'));
            console.log('Container height:', document.getElementById('arazzoViewer').offsetHeight);

            const ui = window.ArazzoUI({
                dom_id: '#arazzoViewer',
                document: specContent,  // Pass the YAML/JSON content directly
                view: 'split'           // Show diagram and docs side-by-side
            });

            console.log('Arazzo UI initialized successfully');
            console.log('UI instance:', ui);

            // Log any errors that might have occurred
            setTimeout(() => {
                console.log('Container after init:', document.getElementById('arazzoViewer').innerHTML.substring(0, 200));
            }, 1000);
        } else {
            throw new Error('Arazzo UI library not loaded. Check that the script loaded correctly.');
        }

    } catch (error) {
        console.error('Error initializing Arazzo UI:', error);
        const viewerContainer = document.getElementById('arazzoViewer');
        viewerContainer.innerHTML = '';

        const errorDiv = document.createElement('div');
        errorDiv.style.padding = '2rem';
        errorDiv.style.textAlign = 'center';
        errorDiv.style.color = '#e74c3c';
        errorDiv.style.fontFamily = 'sans-serif';

        const titleP = document.createElement('p');
        const titleStrong = document.createElement('strong');
        titleStrong.textContent = 'Error loading Arazzo UI';
        titleP.appendChild(titleStrong);

        const messageP = document.createElement('p');
        messageP.style.fontSize = '0.9rem';
        messageP.style.color = '#999';
        messageP.textContent = error.message;

        const consoleP = document.createElement('p');
        consoleP.style.fontSize = '0.85rem';
        consoleP.style.color = '#999';
        consoleP.textContent = 'Check browser console for details';

        errorDiv.appendChild(titleP);
        errorDiv.appendChild(messageP);
        errorDiv.appendChild(consoleP);
        viewerContainer.appendChild(errorDiv);
    }
});
</script>
