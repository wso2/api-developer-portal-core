<head>
    <link rel="stylesheet" href="/technical-styles/api-workflows.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@jentic/arazzo-ui@latest/dist/arazzo-ui.css">
    <script src="https://cdn.jsdelivr.net/npm/@jentic/arazzo-ui@latest/dist/arazzo-ui.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/js-yaml@4.1.0/dist/js-yaml.min.js"></script>
</head>

<main>
    {{> header profile=profile baseUrl=baseUrl devportalMode=devportalMode}}
    {{> sidebar profile=profile baseUrl=baseUrl devportalMode=devportalMode}}

    <div class="flow-detail-section">
        {{!-- Back Button --}}
        <a href="{{baseUrl}}/api-workflows" class="flow-detail-back">
            <i class="bi bi-arrow-left"></i>
            Back
        </a>

        {{!-- Header --}}
        <div class="flow-detail-header">
            <div class="flow-detail-header-content">
                <h1>{{flow.name}}</h1>
                <p>{{flow.description}}</p>
            </div>
            <div class="flow-header-actions">
                {{#unless (eq flow.agentVisibility "HIDDEN")}}
                <button class="btn-prompt" id="openPromptBtn" data-bs-toggle="modal" data-bs-target="#agentPromptModal">
                    <i class="bi bi-file-code"></i>
                    Agent Prompt
                </button>
                {{/unless}}
            </div>
        </div>

        {{!-- Content --}}
        <div class="flow-detail-content">
            {{!-- Arazzo UI Viewer --}}
            <div class="arazzo-viewer-container">
                <div id="arazzoViewer"></div>
            </div>
        </div>
    </div>

    {{> alert}}

    {{!-- ── AGENT PROMPT MODAL ── --}}
    <div class="modal fade" id="agentPromptModal" tabindex="-1" aria-labelledby="agentPromptModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title mb-0" id="agentPromptModalLabel">Agent Prompt</h5>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="api-flow-prompt-toolbar">
                        <span class="small text-muted">Use this prompt to let your AI agent execute the workflow—handling API calls, dependencies, and errors automatically</span>
                        <div class="prompt-modal-toolbar">
                            <button type="button" class="prompt-tool-btn" id="btnDownloadPrompt" title="Download as .txt">
                                <i class="bi bi-download"></i>
                            </button>
                            <button type="button" class="prompt-tool-btn" id="btnCopyPrompt" title="Copy prompt">
                                <i class="bi bi-clipboard"></i>
                            </button>
                            <div class="prompt-run-dropdown">
                                <button type="button" class="btn-run-prompt" id="btnRunPrompt">
                                    <i class="bi bi-play-fill"></i> Run
                                </button>
                                <div class="run-dropdown-menu" id="runDropdownMenu">
                                    <button class="run-option" id="btnRunClaude">Run in Claude</button>
                                    <button class="run-option" id="btnRunChatGPT">Run in ChatGPT</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <pre id="modalAgentPromptText" class="api-flow-prompt-pre">{{flow.agentPrompt}}</pre>
                </div>
            </div>
        </div>
    </div>

    {{!-- Hidden container for spec content --}}
    <textarea id="specContent" style="display: none;">{{flow.content}}</textarea>
</main>

<script>
document.addEventListener('DOMContentLoaded', function() {

    const btnCopyPrompt = document.getElementById('btnCopyPrompt');
    if (btnCopyPrompt) {
        btnCopyPrompt.addEventListener('click', function() {
            const promptText = document.getElementById('modalAgentPromptText').textContent;
            navigator.clipboard.writeText(promptText).then(() => {
                const icon = btnCopyPrompt.querySelector('i');
                icon.className = 'bi bi-clipboard-check';
                setTimeout(() => { icon.className = 'bi bi-clipboard'; }, 2000);
            }).catch(() => showNotification('Failed to copy prompt', 'error'));
        });
    }

    const btnDownloadPrompt = document.getElementById('btnDownloadPrompt');
    if (btnDownloadPrompt) {
        btnDownloadPrompt.addEventListener('click', function() {
            const promptText = document.getElementById('modalAgentPromptText').textContent;
            const blob = new Blob([promptText], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = '{{flow.handle}}.txt';
            a.click();
            URL.revokeObjectURL(url);
        });
    }

    const btnRunPrompt = document.getElementById('btnRunPrompt');
    if (btnRunPrompt) {
        btnRunPrompt.addEventListener('click', function(event) {
            event.stopPropagation();
            document.getElementById('runDropdownMenu').classList.toggle('show');
        });
    }

    const btnRunClaude = document.getElementById('btnRunClaude');
    if (btnRunClaude) {
        btnRunClaude.addEventListener('click', function() {
            const prompt = document.getElementById('modalAgentPromptText').textContent;
            window.open('https://claude.ai/new?q=' + encodeURIComponent(prompt), '_blank');
            document.getElementById('runDropdownMenu').classList.remove('show');
        });
    }

    const btnRunChatGPT = document.getElementById('btnRunChatGPT');
    if (btnRunChatGPT) {
        btnRunChatGPT.addEventListener('click', function() {
            const prompt = document.getElementById('modalAgentPromptText').textContent;
            window.open('https://chatgpt.com/?prompt=' + encodeURIComponent(prompt), '_blank');
            document.getElementById('runDropdownMenu').classList.remove('show');
        });
    }

    document.addEventListener('click', function() {
        const menu = document.getElementById('runDropdownMenu');
        if (menu) menu.classList.remove('show');
    });
});


function showNotification(message, type = 'info') {
    const notification = document.createElement('div');
    notification.className = `notification notification-${type}`;

    const content = document.createElement('div');
    content.className = 'notification-content';

    const icon = document.createElement('i');
    const iconClass = type === 'success' ? 'check-circle' : 'exclamation-circle';
    icon.className = `bi bi-${iconClass}`;

    const messageSpan = document.createElement('span');
    messageSpan.textContent = message;

    content.appendChild(icon);
    content.appendChild(messageSpan);
    notification.appendChild(content);
    document.body.appendChild(notification);

    setTimeout(() => {
        notification.classList.add('show');
    }, 10);

    setTimeout(() => {
        notification.classList.remove('show');
        setTimeout(() => {
            notification.remove();
        }, 300);
    }, 3000);
}

// Initialize Arazzo UI Component
document.addEventListener('DOMContentLoaded', function() {
    try {
        const specContent = document.getElementById('specContent').value.trim();
        const viewerContainer = document.getElementById('arazzoViewer');

        if (!specContent) {
            viewerContainer.innerHTML = '<p style="padding: 2rem; text-align: center; color: #999;">No specification content available</p>';
            return;
        }

        console.log('Initializing Arazzo UI component...');
        console.log('ArazzoUI available:', typeof window.ArazzoUI);

        // Initialize Arazzo UI with the spec content
        // The component accepts inline YAML/JSON strings
        if (window.ArazzoUI) {
            console.log('Starting Arazzo UI initialization...');
            console.log('Container element:', document.getElementById('arazzoViewer'));
            console.log('Container height:', document.getElementById('arazzoViewer').offsetHeight);

            const ui = window.ArazzoUI({
                dom_id: '#arazzoViewer',
                document: specContent,  // Pass the YAML/JSON content directly
                view: 'split'           // Show diagram and docs side-by-side
            });

            console.log('Arazzo UI initialized successfully');
            console.log('UI instance:', ui);

            // Log any errors that might have occurred
            setTimeout(() => {
                console.log('Container after init:', document.getElementById('arazzoViewer').innerHTML.substring(0, 200));
            }, 1000);
        } else {
            throw new Error('Arazzo UI library not loaded. Check that the script loaded correctly.');
        }

    } catch (error) {
        console.error('Error initializing Arazzo UI:', error);
        const viewerContainer = document.getElementById('arazzoViewer');
        viewerContainer.innerHTML = '';

        const errorDiv = document.createElement('div');
        errorDiv.style.padding = '2rem';
        errorDiv.style.textAlign = 'center';
        errorDiv.style.color = '#e74c3c';
        errorDiv.style.fontFamily = 'sans-serif';

        const titleP = document.createElement('p');
        const titleStrong = document.createElement('strong');
        titleStrong.textContent = 'Error loading Arazzo UI';
        titleP.appendChild(titleStrong);

        const messageP = document.createElement('p');
        messageP.style.fontSize = '0.9rem';
        messageP.style.color = '#999';
        messageP.textContent = error.message;

        const consoleP = document.createElement('p');
        consoleP.style.fontSize = '0.85rem';
        consoleP.style.color = '#999';
        consoleP.textContent = 'Check browser console for details';

        errorDiv.appendChild(titleP);
        errorDiv.appendChild(messageP);
        errorDiv.appendChild(consoleP);
        viewerContainer.appendChild(errorDiv);
    }
});
</script>
