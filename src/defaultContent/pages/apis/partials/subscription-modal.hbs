<div id="planModal-{{apiID}}" class="modal custom-modal subscription-plan-modal" tabindex="-1" role="dialog"
    style="display:none;"
    data-org-id="{{@root.orgID}}" data-api-refid="{{#if apiInfo.apiReferenceID}}{{apiInfo.apiReferenceID}}{{else}}{{apiID}}{{/if}}" data-token-based="{{apiInfo.tokenBasedSubscriptionEnabled}}" data-gateway-type="{{apiInfo.gatewayType}}">
    <div class="modal-dialog modal-xl subscription-plan-modal-dialog" role="document">
        <div class="modal-content custom-modal-content">
            <div class="custom-modal-header">
                <h2 class="custom-modal-title m-0">{{#if modalTitle}}{{modalTitle}}{{else}}Choose Your Subscription Plan{{/if}}</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"
                    onclick="closeModal('planModal-{{apiID}}')"></button>
            </div>
            <div class="custom-modal-body">
                <div class="api-banner-content py-4 px-5">
                    <div class="d-flex align-items-center justify-content-between w-100">
                        <div class="col-12 col-md-7">
                            <div class="api-title pb-3">
                                <h4>{{apiInfo.apiName}}</h4>
                                <span class="mb-1"> {{apiInfo.apiVersion}}</span>
                                <p class="api-description">{{apiInfo.apiDescription}}</p>
                            </div>
                        </div>
                        <div class="col-12 col-md-5 text-md-right">
                            {{#if apiInfo.apiImageMetadata.api-icon}}
                            <img class="img-thumbnail api-image-small" src="{{apiInfo.apiImageMetadata.api-icon}}"
                                alt="API Image" />
                            {{else}}
                            <div
                                class="img-thumbnail api-image-small image-icon d-flex justify-content-center align-items-center">
                                {{firstTwoLetters apiInfo.apiName}}</div>
                            {{/if}}
                        </div>
                    </div>
                </div>
                <div id="subscriptionTokenArea-{{apiID}}" class="subscription-token-area px-4" style="display:none;">
                    <!-- Token result will be injected here for platform token-based subscriptions -->
                </div>
                <div id="platformContent-{{apiID}}" class="platform-subscription-content px-4" style="display:none;">
                    <!-- Platform subscription table and plans will be injected here dynamically -->
                </div>
                <div class="subscription-plans-body pb-4" {{#if apiInfo.tokenBasedSubscriptionEnabled}}style="display:none;"{{else if (eq apiInfo.gatewayType "wso2/api-platform")}}style="display:none;"{{/if}}>
                    <div class="subscription-plans-title small">Subscription Plans</div>
                    <p class="subscription-plans-subtitle">Please select the most suitable subscription plan from the
                        options
                        available for this API</p>
                    <input type="hidden" id="modal-selected-app-{{apiID}}" value="" />
                    
                    <div class="row row-gap-4 pt-3">
                        {{#each subscriptionPolicyDetails}}
                        <div class="col-12 col-md-6 col-lg-4">
                            <div id="subscriptionCard-{{policyID}}" class="card dev-card subscription-card">
                                <div class="card-body align-items-center text-center p-0">
                                    <span class="subscription-plans-card-title">{{displayName}}</span>
                                        <div class="mb-3 w-100">
                                            <div class="d-flex flex-column align-items-center gap-2" style="margin: 0 auto;">
                                                <span class="text-muted d-block mb-0" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom:0 !important; min-height: 18px;">Price</span>
                                                {{#if pricingModel}}
                                                    {{#compare pricingModel "===" "FLAT"}}
                                                        {{#if flatAmount}}
                                                        <span class="fw-bold d-inline" style="color: #0f172a; font-size: 22px;">{{currency}} {{formatPrice flatAmount}}<small class="text-muted d-inline" style="font-size: 10px;">/{{formatBillingPeriod billingPeriod}}</small></span>
                                                        {{else}}
                                                        <span class="fw-bold d-inline" style="color: #16a34a; font-size: 22px;">Free</span>
                                                        {{/if}}
                                                    {{else}}
                                                        {{#if (eq pricingModel "VOLUME_TIERS")}}
                                                        <div class="subscription-tier-wrapper mx-auto text-center" style="width: fit-content; min-width: 280px;">
                                                            <details class="subscription-tier-details">
                                                                <summary style="font-size: 12px; font-weight: 600; color: #0f172a; cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: center; gap: 4px;"><span class="tier-chevron" style="font-size: 10px;">&#9654;</span> Tier-based pricing</summary>
                                                                <table class="table table-sm mt-2 mb-0" style="font-size: 11px;">
                                                                    <thead><tr><th style="color: #64748b; font-weight: 600; text-align: center; vertical-align: middle;">Total Request<br>Volume</th><th style="color: #64748b; font-weight: 600; text-align: center; vertical-align: middle;">Flat<br>Price</th><th style="color: #64748b; font-weight: 600; text-align: center; vertical-align: middle;">Price /<br>req</th></tr></thead>
                                                                    <tbody>
                                                                        {{#each pricingMetadata.tiers}}
                                                                        <tr>
                                                                            <td style="text-align: center; vertical-align: middle;">{{formatTierRange startUnit endUnit}}</td>
                                                                            <td style="text-align: center; vertical-align: middle;">{{../currency}} {{formatPrice flatPrice}}</td>
                                                                            <td style="text-align: center; vertical-align: middle;">{{../currency}} {{formatPrice unitPrice}}</td>
                                                                        </tr>
                                                                        {{/each}}
                                                                    </tbody>
                                                                </table>
                                                            </details>
                                                        </div>
                                                        {{#if billingPeriod}}
                                                        <span class="badge d-inline-block mt-2 mb-1" style="background-color: #e0f2fe; color: #0369a1; font-size: 9px; padding: 3px 8px; border-radius: 10px;">Billed {{formatBillingPeriod billingPeriod}}</span>
                                                        {{/if}}
                                                        {{else if (eq pricingModel "GRADUATED_TIERS")}}
                                                        <div class="subscription-tier-wrapper mx-auto text-center" style="width: fit-content; min-width: 280px;">
                                                            <details class="subscription-tier-details">
                                                                <summary style="font-size: 12px; font-weight: 600; color: #0f172a; cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: center; gap: 4px;"><span class="tier-chevron" style="font-size: 10px;">&#9654;</span> Tier-based pricing</summary>
                                                                <table class="table table-sm mt-2 mb-0" style="font-size: 11px;">
                                                                    <thead><tr><th style="color: #64748b; font-weight: 600; text-align: center; vertical-align: middle;">Request<br>Range</th><th style="color: #64748b; font-weight: 600; text-align: center; vertical-align: middle;">Flat<br>Price</th><th style="color: #64748b; font-weight: 600; text-align: center; vertical-align: middle;">Price /<br>req</th></tr></thead>
                                                                    <tbody>
                                                                        {{#each pricingMetadata.tiers}}
                                                                        <tr>
                                                                            <td style="text-align: center; vertical-align: middle;">{{formatTierRange startUnit endUnit}}</td>
                                                                            <td style="text-align: center; vertical-align: middle;">{{../currency}} {{formatPrice flatPrice}}</td>
                                                                            <td style="text-align: center; vertical-align: middle;">{{../currency}} {{formatPrice unitPrice}}</td>
                                                                        </tr>
                                                                        {{/each}}
                                                                    </tbody>
                                                                </table>
                                                            </details>
                                                        </div>
                                                        {{#if billingPeriod}}
                                                        <span class="badge d-inline-block mt-2 mb-1" style="background-color: #e0f2fe; color: #0369a1; font-size: 9px; padding: 3px 8px; border-radius: 10px;">Billed {{formatBillingPeriod billingPeriod}}</span>
                                                        {{/if}}
                                                        {{else}}
                                                        {{#if unitAmount}}
                                                        <span class="fw-bold d-inline" style="color: #0f172a; font-size: 22px;">{{currency}} {{formatPrice unitAmount}}<small class="text-muted d-inline" style="font-size: 10px;">/req</small></span>
                                                        {{#if billingPeriod}}
                                                        <span class="badge d-inline-block mt-2" style="background-color: #e0f2fe; color: #0369a1; font-size: 9px; padding: 3px 8px; border-radius: 10px;">Billed {{formatBillingPeriod billingPeriod}}</span>
                                                        {{/if}}
                                                        {{else}}
                                                        <span class="fw-bold d-inline" style="color: #16a34a; font-size: 22px;">Free</span>
                                                        {{/if}}
                                                        {{/if}}
                                                    {{/compare}}
                                                {{else}}
                                                    <span class="fw-bold d-inline" style="color: #16a34a; font-size: 22px;">Free</span>
                                                {{/if}}
                                                <span class="text-muted d-block mt-3 mb-0" style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom:0 !important; min-height: 18px;">Rate Limit</span>
                                                <span class="fw-bold d-inline" style="color: #0f172a; font-size: 25px;">{{requestCount}}<small class="text-muted d-inline" style="font-size: 11px;">&nbsp;req/min</small></span>
                                            </div>
                                        </div>
                                                {{#if ../apiInfo.tokenBasedSubscriptionEnabled}}
                                                    <button id="subscribe-btn-{{policyID}}" type="button"
                                                        class="common-btn-primary p-1 ps-2 pe-2 w-100 subscription-plan-subscribe-btn {{#if @root.isReadOnlyMode}}disabled{{/if}}"
                                                        data-org-id="{{@root.orgID}}"
                                                        data-api-id="{{#if apiID}}{{apiID}}{{else}}{{../apiID}}{{/if}}"
                                                        data-policy-id="{{policyID}}"
                                                        data-policy-name="{{policyName}}"
                                                        data-display-name="{{displayName}}"
                                                        data-external-price-id="{{pricingMetadata.external.priceId}}"
                                                        data-is-paid="{{#if isPaid}}true{{else}}false{{/if}}"
                                                        {{#unless @root.isReadOnlyMode}}onclick="handlePlanSubscription(this)"{{/unless}}
                                                        {{#if @root.isReadOnlyMode}}disabled aria-disabled="true"{{/if}}>Subscribe</button>
                                                {{else if (eq ../apiInfo.gatewayType "wso2/api-platform")}}
                                                    <button id="subscribe-btn-{{policyID}}" type="button"
                                                        class="common-btn-primary p-1 ps-2 pe-2 w-100 subscription-plan-subscribe-btn {{#if @root.isReadOnlyMode}}disabled{{/if}}"
                                                        data-org-id="{{@root.orgID}}"
                                                        data-api-id="{{#if apiID}}{{apiID}}{{else}}{{../apiID}}{{/if}}"
                                                        data-policy-id="{{policyID}}"
                                                        data-policy-name="{{policyName}}"
                                                        data-display-name="{{displayName}}"
                                                        data-external-price-id="{{pricingMetadata.external.priceId}}"
                                                        data-is-paid="{{#if isPaid}}true{{else}}false{{/if}}"
                                                        {{#unless @root.isReadOnlyMode}}onclick="handlePlanSubscription(this)"{{/unless}}
                                                        {{#if @root.isReadOnlyMode}}disabled aria-disabled="true"{{/if}}>Subscribe</button>
                                                {{else}}
                                                    {{#if ../subID}}
                                                        {{!-- Update mode: app already known, show Update button directly --}}
                                                        <button id="subscribe-btn-{{policyID}}" type="button"
                                                            class="common-btn-primary p-1 ps-2 pe-2 w-100 subscription-plan-subscribe-btn {{#if @root.isReadOnlyMode}}disabled{{/if}}"
                                                            data-external-price-id="{{pricingMetadata.external.priceId}}"
                                                            data-is-paid="{{#if isPaid}}true{{else}}false{{/if}}"
                                                            {{#unless @root.isReadOnlyMode}}onclick="showSubscribeButtonLoading(this); updateSubscription('{{@root.orgID}}', '{{../appID}}', '{{../apiID}}', '{{#if ../refID}}{{../refID}}{{else}}{{../apiID}}{{/if}}', '{{policyID}}', '{{policyName}}', '{{../selectedPlan}}', '{{../subID}}')"{{/unless}}
                                                            {{#if @root.isReadOnlyMode}}disabled aria-disabled="true"{{/if}}>Update</button>
                                                    {{else}}
                                                        {{!-- App-based subscription flow: show dropdown above a full-width Subscribe button --}}
                                                        <div class="p-3 d-flex flex-column align-items-stretch">
                                                            <div class="mb-2">
                                                                <div class="custom-dropdown show" id="customDropdown-{{policyID}}" style="min-width: 100%; marginBottom: 30px">
                                                                    <input type="hidden" id="selectedAppId-{{policyID}}" value="" />
                                                                    <div class="custom-select-container" style="width: 100%; margin-bottom: 8px;">
                                                                        <div class="select-selected" aria-expanded="false">
                                                                            <span class="selected-text">Create an app</span>
                                                                            <span class="select-arrow"></span>
                                                                        </div>
                                                                        <div class="select-items" role="listbox">
                                                                            <div class="select-search-container">
                                                                                <input type="text" class="select-search-input {{#if @root.isReadOnlyMode}}d-none{{/if}}" placeholder="Find or create an application..."
                                                                                    aria-label="Search applications">
                                                                            </div>
                                                                            <div class="select-items-container">
                                                                                {{#each (filter ../applications "subscriptionStatus" "CANCELED" false)}}
                                                                                <div class="select-item {{#if subscribed}}disabled{{/if}}" role="button" data-value="{{id}}" data-app-name="{{name}}">
                                                                                    <div class="d-flex flex-column flex-grow-1">
                                                                                        <span class="fw-semibold">{{name}}</span>
                                                                                        {{#if subscriptionPolicy}}
                                                                                        <small style="font-size: 11px; margin-top: 3px;">
                                                                                            <span class="badge" style="background-color: #e0f2fe; color: #0369a1; padding: 2px 8px; border-radius: 10px; font-weight: 600; font-size: 10px;">
                                                                                                {{subscriptionPolicy.policyName}}
                                                                                            </span>
                                                                                        </small>
                                                                                        {{/if}}
                                                                                    </div>
                                                                                    {{#if subscribed}}
                                                                                        {{#if (eq subscriptionStatus "ACTIVE")}}
                                                                                        <span class="badge" style="background:#ecfdf5;color:#047857;padding:2px 8px;border-radius:10px;font-weight:700;font-size:10px;flex-shrink:0;">Active</span>
                                                                                        {{else if (eq subscriptionStatus "TRIALING")}}
                                                                                        <span class="badge" style="background:#eff6ff;color:#1d4ed8;padding:2px 8px;border-radius:10px;font-weight:700;font-size:10px;flex-shrink:0;">Trial</span>
                                                                                        {{else if (eq subscriptionStatus "PAST_DUE")}}
                                                                                        <span class="badge" style="background:#fef2f2;color:#b91c1c;padding:2px 8px;border-radius:10px;font-weight:700;font-size:10px;flex-shrink:0;">Past due</span>
                                                                                        {{else if (eq subscriptionStatus "CANCEL_SCHEDULED")}}
                                                                                        <span class="badge" style="background:#fff7ed;color:#c2410c;padding:2px 8px;border-radius:10px;font-weight:700;font-size:10px;flex-shrink:0;">Cancels soon</span>
                                                                                        {{/if}}
                                                                                    {{/if}}
                                                                                </div>
                                                                                {{/each}}
                                                                            </div>
                                                                            <div class="create-app-container" style="display: none;">
                                                                                <div class="create-app-option" role="button">
                                                                                    Create application "<span class="search-term"></span>"
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <button id="subscribe-btn-{{policyID}}" type="button"
                                                                class="common-btn-primary w-100 subscription-plan-subscribe-btn {{#if @root.isReadOnlyMode}}disabled{{/if}}"
                                                                data-external-price-id="{{pricingMetadata.external.priceId}}"
                                                                data-is-paid="{{#if isPaid}}true{{else}}false{{/if}}"
                                                                {{#unless @root.isReadOnlyMode}}onclick="showSubscribeButtonLoading(this); subscribe('{{@root.orgID}}', '', '{{../apiID}}', '{{#if ../apiReferenceID}}{{../apiReferenceID}}{{else}}{{../apiID}}{{/if}}', '{{policyID}}', '{{policyName}}', this)"{{/unless}}
                                                                {{#if @root.isReadOnlyMode}}disabled aria-disabled="true"{{/if}}>Subscribe</button>
                                                        </div>
                                                    {{/if}}
                                                {{/if}}
                                </div>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </div>
                <div class="d-flex justify-content-end mb-3" id="applicationKeyUpdateButtonContainer">
                    <button class="common-btn-outlined pr-3 me-3" type="button"
                        onclick="closeModal('planModal-{{apiID}}')">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</div>
