<section class="apis-section">
  <div class="container-fluid">
    <div class="apilist-hero-container">
      <div class="apilist-hero-content">
        <div class="apilist-hero-header">
          <h1 class="apilist-hero-title">
            Discover, Integrate, and Innovate with Scalable APIs
          </h1>
          <div class="apilist-hero-description">
            Explore our extensive API catalog and discover how to integrate them seamlessly into your application.
          </div>
        </div>
      </div>
      <div class="col-lg-6 col-md-12 apilist-hero-image">
        <img
          src="https://raw.githubusercontent.com/wso2/docs-bijira/refs/heads/main/en/devportal-theming/apisHeroImg.png"
          alt="Hero Image" class="img-fluid" />
      </div>
    </div>
  </div>
  <div class="container-fluid apilist-container">
    <div class="search-container">
      <div class="search-input">
        <img src="https://raw.githubusercontent.com/wso2/docs-bijira/refs/heads/main/en/devportal-theming/search.svg"
          alt="search" class="search-icon" />
        <input type="text" id="query" placeholder="Search APIs" autocomplete="off" />
      </div>
    </div>
    <div class="row row-gap-4">
      {{#if (eq apiMetadata.length 0)}}
      <div class="ps-3" id="no-subscription">
        <div class="api-info-box">
          <div class="api-info-content">
            <div class="api-info-title">
              No APIs available.
            </div>
          </div>
        </div>
      </div>
      {{/if}}
      {{#apiMetadata}}
      {{#unless (eq apiInfo.apiType "MCP")}}
      <div class="col-lg-4 col-md-6 col-sm-12" id="apiCard-{{apiID}}">
        <div class="card api-card d-flex flex-column">
          <div class="api-card-header d-flex align-items-center gap-3 position-relative overflow-hidden"
            data-href="{{../baseUrl}}/api/{{apiHandle}}" style="cursor: pointer;">
               {{#if apiInfo.apiImageMetadata.api-icon}}
                  <img src="{{apiInfo.apiImageMetadata.api-icon}}" class="api-card-img" alt="..." />
                {{else}}
                  <div class="image-icon">{{firstTwoLetters apiInfo.apiName}}</div>
                {{/if}}
            <div class="flex-grow-1">
              <h5 class="api-card-title mb-0">{{apiInfo.apiName}}</h5>
              <div class="d-flex align-items-center gap-2">
                <p class="mb-0 mt-1" style="font-size: 16px;">{{apiInfo.apiVersion}}</p>
                <div class="type-badge badge-custom2" style="display: flex; flex-direction: row; align-items: center;">
                  <div style="margin-right: 8px; display: flex;">
                    {{#if (eq apiInfo.apiType "WS")}}
                    <img
                      src="https://raw.githubusercontent.com/wso2/docs-bijira/refs/heads/main/en/devportal-theming/WebSocket.svg"
                      style=" height: 16px; object-fit: contain;"
                    />
                    {{else if (eq apiInfo.apiType "GRAPHQL")}}
                    <img
                      src="https://raw.githubusercontent.com/wso2/docs-bijira/refs/heads/main/en/devportal-theming/graphql.svg"
                      style="height: 16px; object-fit: contain;"
                     />
                    {{else if (eq apiInfo.apiType "WEBSUB")}}
                    <img
                      src="https://raw.githubusercontent.com/wso2/docs-bijira/refs/heads/main/en/devportal-theming/graphql.svg"
                      style="height: 16px; object-fit: contain;"
                     />
                    {{else}}
                    <img
                      src="https://raw.githubusercontent.com/wso2/docs-bijira/refs/heads/main/en/devportal-theming/REST.svg"
                      style=" height: 16px; object-fit: contain;"
                    />
                    {{/if}}
                  </div>
                  {{#if (eq apiInfo.apiType "WS")}}
                  <span>WebSocket</span>
                  {{else if (eq apiInfo.apiType "WEBSUB")}}
                  <span>WebSub</span>
                  {{else}}
                  <span>{{apiInfo.apiType}}</span>
                  {{/if}}
                </div>
              </div>
              <div class="api-card-chips mt-2">
                {{#unless (eq apiInfo.agentVisibility "HIDDEN")}}
                <span class="api-agent-chip api-agent-chip--ready"
                    title="AI agents can discover and use this API">
                    <span class="api-agent-chip__dot"></span>
                    <i class="bi bi-robot"></i> AI Ready
                </span>
                {{/unless}}
              </div>
            </div>
            {{#if ../isAuthenticated}}
            {{#if apiInfo.tokenBasedSubscriptionEnabled}}
            <div class="subscription-flag fw-bold" style="display: {{#if hasPlatformSubscription}}block{{else}}none{{/if}};">Subscribed</div>
            {{else if (eq apiInfo.gatewayType "wso2/api-platform")}}
            <div class="subscription-flag fw-bold" style="display: {{#if hasPlatformSubscription}}block{{else}}none{{/if}};">Subscribed</div>
            {{else}}
            <div class="subscription-flag fw-bold" style="display: {{#if (some applications "subscribed")}}block{{else}}none{{/if}};">Subscribed</div>
            {{/if}}
            {{/if}}
          </div>
          <div class="api-card-body flex-grow-1" data-href="{{../baseUrl}}/api/{{apiHandle}}" style="cursor: pointer;">
            <div class="truncate-text fw-light apilisting-api-description small mb-3">{{apiInfo.apiDescription}}</div>
            
            {{#if ../isAuthenticated}}
              {{#if subscriptionPolicies}}
                <div class="plans-summary-card">
                  <div class="plans-summary-card__row">
                    <div class="plans-summary-card__left">
                      <span class="plans-summary-card__label">
                        <i class="fas fa-tags" aria-hidden="true"></i>
                        Plans
                        <span class="plans-summary-card__count">({{subscriptionPolicies.length}})</span>
                      </span>

                      {{!-- optional: show “Free available” if any plan is free --}}
                      {{#if (some subscriptionPolicies "isFreePlan")}}
                        <span class="plans-summary-card__pill plans-summary-card__pill--free">Free available</span>
                      {{/if}}
                    </div>

                    <a class="plans-summary-card__link" href="{{../baseUrl}}/api/{{apiHandle}}#subscriptionPlans">
                      View plans
                    </a>
                  </div>
                </div>
              {{/if}}
            {{/if}}
            <div class="row">
              <div class="apilisting-tags">
                {{#apiInfo.tags}}
                <span class="badge badge-custom2">{{this}}</span>
                {{/apiInfo.tags}}
              </div>
            </div>
          </div>
          {{#if ../isAuthenticated}}
          {{#if apiInfo.tokenBasedSubscriptionEnabled}}
          <hr class="card-separator" />
          {{else if subscriptionPolicies.length}}
          <hr class="card-separator" />
          {{/if}}
          {{/if}}
          <div class="api-card-footer">
            <div id="btnSection" class="d-flex align-items-center gap-2 w-100">
              {{#if ../isAuthenticated}}
              <div id="subscriptionBox" class="subscription-container w-100">
                {{#if apiInfo.tokenBasedSubscriptionEnabled}}
                  {{> subscription-modal apiID=apiID apiInfo=apiInfo apiReferenceID=apiReferenceID}}
                  <a type="button" class="common-btn-primary w-100 open-modal-btn {{#if @root.isReadOnlyMode}}is-readonly{{/if}}"
                    {{#unless @root.isReadOnlyMode}}data-modal="planModal-{{apiID}}"{{/unless}}
                    {{#if @root.isReadOnlyMode}}aria-disabled="true"{{/if}}>Subscribe</a>
                {{else if (eq apiInfo.gatewayType "wso2/api-platform")}}
                  {{#if subscriptionPolicies.length}}
                  {{> subscription-modal apiID=apiID apiInfo=apiInfo apiReferenceID=apiReferenceID}}
                  <a type="button" class="common-btn-primary w-100 open-modal-btn {{#if @root.isReadOnlyMode}}is-readonly{{/if}}"
                    {{#unless @root.isReadOnlyMode}}data-modal="planModal-{{apiID}}"{{/unless}}
                    {{#if @root.isReadOnlyMode}}aria-disabled="true"{{/if}}>Subscribe</a>
                  {{/if}}
                {{else}}
                {{> subscription-plans apiInfo=apiInfo apiName=apiInfo.apiName}}
                {{#if subscriptionPolicies.length}}
                  {{!-- Application selection moved into the subscription modal. --}}
                  <a type="button" class="common-btn-primary w-100 open-modal-btn {{#if @root.isReadOnlyMode}}is-readonly{{/if}}"
                    {{#unless @root.isReadOnlyMode}}data-modal="planModal-{{apiID}}"{{/unless}}
                    {{#if @root.isReadOnlyMode}}aria-disabled="true"{{/if}}>Subscribe</a>
                {{/if}}
                {{/if}}
              </div>
              {{/if}}
            </div>
            
            <div class="message-overlay hidden">
              <div class="message-content">
                <i class="bi message-icon"></i>
                <p class="message-text"></p>
              </div>
              <button type="button" class="close-message" aria-label="Close message">&times;</button>
            </div>
          </div>
        </div>
      </div>
      {{/unless}}
      {{/apiMetadata}}
    </div>
  </div>
  <script>
    (function(){
      function findClosest(el, selector){
        while(el && el !== document){
          if(el.matches && el.matches(selector)) return el;
          el = el.parentNode;
        }
        return null;
      }

      document.addEventListener('click', function(e){
        var modalTrigger = findClosest(e.target, '[data-modal]');
        if(modalTrigger){
          e.preventDefault();
          if(modalTrigger.classList.contains('is-readonly') || modalTrigger.getAttribute('aria-disabled') === 'true'){
            return;
          }
          if(typeof loadModal === 'function'){
            loadModal(modalTrigger.getAttribute('data-modal'));
          } else {
            var id = modalTrigger.getAttribute('data-modal');
            var el = document.getElementById(id);
            if(el) {
              el.style.display = 'flex';
              document.body.classList.add('modal-open');
              if(typeof prepareSubscriptionModal === 'function') {
                try { prepareSubscriptionModal(id); } catch(err) { /* noop */ }
              }
            }
          }
          return;
        }

        var nav = findClosest(e.target, '[data-href]');
        if(nav){
          var href = nav.getAttribute('data-href');
          if(href){ window.location.href = href; }
        }
      }, false);
    })();
  </script>
</section>
