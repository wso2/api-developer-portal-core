<head>
  <script src='/technical-scripts/add-application-form.js' defer></script>
  <script src="/technical-scripts/oauth2-key-generation.js" defer></script>
  <script src='/technical-scripts/platform-subscription.js' defer></script>
  <script src='/technical-scripts/subscription-modal.js' defer></script>
  <script src='/technical-scripts/api-agent-prompt.js' defer></script>
  <link rel="stylesheet" href="/technical-styles/agent-prompt.css">
  <script type="application/json" id="apiAgentData">{"baseUrl":"{{baseUrl}}","apiHandle":"{{apiMetadata.apiHandle}}"}</script>
</head>
<main>
    {{> header profile=profile baseUrl=baseUrl devportalMode=devportalMode showApiWorkflowsNav=showApiWorkflowsNav }}
    {{> sidebar profile=profile baseUrl=baseUrl devportalMode=devportalMode showPlatformApiKeysNav=showPlatformApiKeysNav showApiWorkflowsNav=showApiWorkflowsNav }}
    {{> api-detail-banner }}
    {{#if loadDefault}}
    {{> api-default}}
    {{else}}
    {{> api-content }}
    {{/if}}
    {{> api-subscription-plans}}
    {{> create-app }}
    {{> warning modalTitle="Confirm" modalMessage="" modalFunction="" }}
    {{> alert }}

    {{!-- ── AGENT PROMPT MODAL ── --}}
    {{#if showApiWorkflowsNav}}
    {{#unless (eq apiMetadata.apiInfo.agentVisibility "HIDDEN")}}
    <div class="modal fade" id="apiAgentPromptModal" tabindex="-1" aria-labelledby="apiAgentPromptModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title mb-0" id="apiAgentPromptModalLabel">Agent Prompt</h5>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="api-flow-prompt-toolbar">
                        <span class="small text-muted">Use this prompt to let your AI agent discover and call this API automatically</span>
                        <div class="prompt-modal-toolbar">
                            <button type="button" class="prompt-tool-btn" id="apiBtnDownloadPrompt" title="Download as .txt">
                                <i class="bi bi-download"></i>
                            </button>
                            <button type="button" class="prompt-tool-btn" id="apiBtnCopyPrompt" title="Copy prompt">
                                <i class="bi bi-copy"></i>
                            </button>
                            <div class="prompt-run-dropdown">
                                <button type="button" class="btn-run-prompt" id="apiBtnRunPrompt">
                                    <i class="bi bi-play-fill"></i> Run
                                </button>
                                <div class="run-dropdown-menu" id="apiRunDropdownMenu">
                                    <button class="run-option" id="apiBtnRunClaude">Run in Claude</button>
                                    <button class="run-option" id="apiBtnRunChatGPT">Run in ChatGPT</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <pre id="apiAgentPromptText" class="api-flow-prompt-pre">Loading...</pre>
                </div>
            </div>
        </div>
    </div>

    {{/unless}}
    {{/if}}
</main>
