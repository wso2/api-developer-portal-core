<head>
  <script src='/technical-scripts/add-application-form.js' defer></script>
  <script src="/technical-scripts/oauth2-key-generation.js" defer></script>
  <script src='/technical-scripts/platform-subscription.js' defer></script>
  <script src='/technical-scripts/subscription-modal.js' defer></script>
  <link rel="stylesheet" href="/technical-styles/agent-prompt.css">
</head>
<main>
    {{> header profile=profile baseUrl=baseUrl devportalMode=devportalMode showApiWorkflowsNav=showApiWorkflowsNav }}
    {{> sidebar profile=profile baseUrl=baseUrl devportalMode=devportalMode showPlatformApiKeysNav=showPlatformApiKeysNav showApiWorkflowsNav=showApiWorkflowsNav }}
    {{> api-detail-banner }}
    {{#if loadDefault}}
    {{> api-default}}
    {{else}}
    {{> api-content }}
    {{/if}}
    {{> api-subscription-plans}}
    {{> create-app }}
    {{> warning modalTitle="Confirm" modalMessage="" modalFunction="" }}
    {{> alert }}

    {{!-- ── AGENT PROMPT MODAL ── --}}
    {{#if showApiWorkflowsNav}}
    {{#unless (eq apiMetadata.apiInfo.agentVisibility "HIDDEN")}}
    <div class="modal fade" id="apiAgentPromptModal" tabindex="-1" aria-labelledby="apiAgentPromptModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title mb-0" id="apiAgentPromptModalLabel">Agent Prompt</h5>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="api-flow-prompt-toolbar">
                        <span class="small text-muted">Use this prompt to let your AI agent discover and call this API automatically</span>
                        <div class="prompt-modal-toolbar">
                            <button type="button" class="prompt-tool-btn" id="apiBtnDownloadPrompt" title="Download as .txt">
                                <i class="bi bi-download"></i>
                            </button>
                            <button type="button" class="prompt-tool-btn" id="apiBtnCopyPrompt" title="Copy prompt">
                                <i class="bi bi-copy"></i>
                            </button>
                            <div class="prompt-run-dropdown">
                                <button type="button" class="btn-run-prompt" id="apiBtnRunPrompt">
                                    <i class="bi bi-play-fill"></i> Run
                                </button>
                                <div class="run-dropdown-menu" id="apiRunDropdownMenu">
                                    <button class="run-option" id="apiBtnRunClaude">Run in Claude</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <pre id="apiAgentPromptText" class="api-flow-prompt-pre">Loading...</pre>
                </div>
            </div>
        </div>
    </div>

    <script>
    (function() {
        const mdUrl = '{{baseUrl}}/api/{{apiMetadata.apiHandle}}.md';
        const apiName = '{{apiMetadata.apiHandle}}';
        let promptLoaded = false;

        const modalEl = document.getElementById('apiAgentPromptModal');
        if (modalEl) {
            modalEl.addEventListener('show.bs.modal', function() {
                if (promptLoaded) return;
                fetch(mdUrl)
                    .then(r => r.text())
                    .then(text => {
                        document.getElementById('apiAgentPromptText').textContent = text;
                        promptLoaded = true;
                    })
                    .catch(() => {
                        document.getElementById('apiAgentPromptText').textContent = 'Failed to load agent prompt.';
                    });
            });
        }

        const apiBtnCopyPrompt = document.getElementById('apiBtnCopyPrompt');
        if (apiBtnCopyPrompt) {
            apiBtnCopyPrompt.addEventListener('click', function() {
                const text = document.getElementById('apiAgentPromptText').textContent;
                navigator.clipboard.writeText(text).then(() => {
                    const icon = apiBtnCopyPrompt.querySelector('i');
                    icon.className = 'bi bi-check2';
                    setTimeout(() => { icon.className = 'bi bi-copy'; }, 2000);
                });
            });
        }

        const apiBtnDownloadPrompt = document.getElementById('apiBtnDownloadPrompt');
        if (apiBtnDownloadPrompt) {
            apiBtnDownloadPrompt.addEventListener('click', function() {
                const text = document.getElementById('apiAgentPromptText').textContent;
                const blob = new Blob([text], { type: 'text/plain' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = apiName + '.txt';
                a.click();
                URL.revokeObjectURL(url);
            });
        }

        const apiBtnRunPrompt = document.getElementById('apiBtnRunPrompt');
        if (apiBtnRunPrompt) {
            apiBtnRunPrompt.addEventListener('click', function(e) {
                e.stopPropagation();
                document.getElementById('apiRunDropdownMenu').classList.toggle('show');
            });
        }

        const apiBtnRunClaude = document.getElementById('apiBtnRunClaude');
        if (apiBtnRunClaude) {
            apiBtnRunClaude.addEventListener('click', function() {
                const text = document.getElementById('apiAgentPromptText').textContent;
                window.open('https://claude.ai/new?q=' + encodeURIComponent(text), '_blank');
                document.getElementById('apiRunDropdownMenu').classList.remove('show');
            });
        }

        document.addEventListener('click', function() {
            const menu = document.getElementById('apiRunDropdownMenu');
            if (menu) menu.classList.remove('show');
        });
    })();
    </script>
    {{/unless}}
    {{/if}}
</main>
