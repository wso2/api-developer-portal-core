<section class="api-banner-section">
  <div class="container-fluid">
    <div class="api-banner-content align-items-center">
      <div class="col-12 col-md-7">
        <div class="api-title">
          <span class="badge api-badge-custom1">{{apiMetadata.apiInfo.apiCategory}}</span>
          <h4>{{apiMetadata.apiInfo.apiName}}</h4>
          <div class="api-version-row">
            <p class="api-version">{{apiMetadata.apiInfo.apiVersion}}</p>
            {{#if showApiWorkflowsNav}}
            {{#unless (eq apiMetadata.apiInfo.agentVisibility "HIDDEN")}}
            <span class="api-agent-chip api-agent-chip--ready"
                title="AI agents can discover and use this API">
                <span class="api-agent-chip__dot"></span>
                <i class="bi bi-robot"></i> AI Ready
            </span>
            {{/unless}}
            {{/if}}
          </div>
        </div>
        <p class="api-description">{{apiMetadata.apiInfo.apiDescription}}</p>
        <hr style="opacity: 0.3; margin: 8px 0; border: none; height: 1px; background-color: #ccc;">
        <div class="api-tags">
          {{#apiMetadata.apiInfo.tags}}
          <span class="badge api-badge-custom2">{{this}}</span>
          {{/apiMetadata.apiInfo.tags}}
        </div>


        <div class="api-details-btn">
          {{!-- Subscribe --}}
          {{#if apiMetadata.apiInfo.tokenBasedSubscriptionEnabled}}
            {{#unless platformSubscriptions.length}}
          <a type="button" class="common-btn-primary" href="#subscriptionPlans">Subscribe</a>
            {{/unless}}
          {{else if (eq apiMetadata.apiInfo.gatewayType "wso2/api-platform")}}
          {{!-- Platform API without token-based subscription: no subscribe button --}}
          {{else}}
          <a type="button" class="common-btn-primary" href="#subscriptionPlans">Subscribe</a>
          {{/if}}
          {{!-- Subscriptions --}}
          {{#if (eq apiMetadata.apiInfo.gatewayType "wso2/api-platform")}}
            {{#if apiMetadata.apiInfo.tokenBasedSubscriptionEnabled}}
              {{#if subscriptionPlans.length}}
          <a type="button" class="common-btn-outlined" href="{{baseUrl}}/api/{{apiMetadata.apiHandle}}/subscriptions">Subscriptions</a>
              {{/if}}
            {{/if}}
          {{else}}
          <a type="button" class="common-btn-outlined" href="{{baseUrl}}/api/{{apiMetadata.apiHandle}}/subscriptions">Subscriptions</a>
          {{/if}}
          {{#if showPlatformApiKeysNav}}
          <a type="button" class="common-btn-outlined" href="{{baseUrl}}/api/{{apiMetadata.apiHandle}}/api-keys">API Keys</a>
          {{/if}}
          {{!-- Documentation (icon) / Download --}}
          {{#in apiMetadata.apiInfo.apiType values="REST,WS,WEBSUB,GRAPHQL,MCP"}}
          <a type="button" class="common-btn-outlined" href="{{baseUrl}}/api/{{apiMetadata.apiHandle}}/docs/specification">Documentation</a>
          {{else}}
          <a type="button" class="common-btn-outlined" href="{{{schemaUrl}}}" download>Download</a>
          {{/in}}
        </div>
      </div>
      <div class="col-12 col-md-5 api-banner-icon">
        {{#if apiMetadata.apiInfo.apiImageMetadata.api-icon}}
        <img class="img-thumbnail api-image" src="{{apiMetadata.apiInfo.apiImageMetadata.api-icon}}" alt="API Image" />
        {{else}}
        <div class="img-thumbnail api-image image-icon d-flex justify-content-center align-items-center">{{firstTwoLetters apiMetadata.apiInfo.apiName}}</div>
        {{/if}}
        {{#if showApiWorkflowsNav}}
        {{#unless (eq apiMetadata.apiInfo.agentVisibility "HIDDEN")}}
        <button type="button" class="btn-icon-ai api-banner-ai-btn" data-bs-toggle="modal" data-bs-target="#apiAgentPromptModal">
          <img src="/images/ai-stars-icon.svg" width="18" height="18" aria-hidden="true" alt="">
          <span class="btn-icon-tooltip">Try with AI</span>
        </button>
        {{/unless}}
        {{/if}}
      </div>
    </div>
  </div>
</section>
