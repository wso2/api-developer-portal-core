# Developer Portal — configuration reference
# Copy this file to config.yaml and fill in the values you want to override.
# Unset fields fall back to the built-in defaults in sample_config.yaml.
# All values can also be overridden via DP_* environment variables (highest priority).
#
# Priority: DP_* env vars  >  secret.yaml  >  config.yaml  >  sample_config.yaml defaults
#
# Secrets (db.password, identityProvider.clientSecret, etc.) belong in secret.yaml,
# not here. Copy sample_secret.yaml → secret.yaml and fill in your secrets there.

# ─────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────
db:
  host: localhost          # env: DP_DB_HOST
  port: 5432               # env: DP_DB_PORT
  username: postgres       # env: DP_DB_USER
  database: devportal      # env: DP_DB_NAME
  dialect: postgres

# ─────────────────────────────────────────────────────────
# Portal bootstrap
# ─────────────────────────────────────────────────────────
portal:
  orgName: ACME            # env: DP_PORTAL_ORG_NAME
                           # Name used when auto-creating the default org on first startup.
                           # Has no effect if an org already exists in the database.

# ─────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────
baseUrl: "http://localhost:3000"   # env: DP_BASE_URL
defaultPort: 3000
mode: production           # production | development

advanced:
  http: true               # Set false to enable HTTPS (requires serverCerts)
  dbSslDialectOption: false

generateDefaultSubPolicies: true   # Create Bronze/Silver/Gold/Unlimited plans on first run

# ─────────────────────────────────────────────────────────
# Identity Provider (OIDC)
# ─────────────────────────────────────────────────────────
identityProvider:
  name: IS
  issuer: "https://localhost:9443/oauth2/token"               # env: DP_OIDC_ISSUER
  authorizationURL: "https://localhost:9443/oauth2/authorize" # env: DP_OIDC_AUTH_URL
  tokenURL: "https://localhost:9443/oauth2/token"             # env: DP_OIDC_TOKEN_URL
  userInfoURL: "https://localhost:9443/oauth2/userinfo"
  clientId: "<CLIENT_ID>"                                     # env: DP_OIDC_CLIENT_ID
  callbackURL: "http://localhost:3000/ACME/callback"          # env: DP_OIDC_CALLBACK_URL
  scope: "openid profile"                                     # env: DP_OIDC_SCOPE
  logoutURL: "https://localhost:9443/oidc/logout"             # env: DP_OIDC_LOGOUT_URL
  logoutRedirectURI: "http://localhost:3000/ACME"
  jwksURL: "https://localhost:9443/oauth2/jwks"               # env: DP_OIDC_JWKS_URL
  certificate: ""
  signUpURL: ""

# ─────────────────────────────────────────────────────────
# Control Plane (WSO2 API Manager / Choreo)
# ─────────────────────────────────────────────────────────
controlPlane:
  enabled: false
  url: ""
  graphqlURL: ""
  disableCertValidation: false
  pathToCertificate: "./resources/security/client-truststore.pem"

# ─────────────────────────────────────────────────────────
# Redis (optional caching)
# ─────────────────────────────────────────────────────────
redis:
  enabled: false
  host: ""
  port: 6379
  db: 0

# ─────────────────────────────────────────────────────────
# HTTPS server certs (only needed when advanced.http = false)
# ─────────────────────────────────────────────────────────
# serverCerts:
#   pathToCert: "./resources/security/client-truststore.pem"
#   pathToPK: "./resources/security/private-key.pem"
#   pathToCA: "./resources/security/client-truststore.pem"

# ─────────────────────────────────────────────────────────
# Default admin user (development / testing only)
# ─────────────────────────────────────────────────────────
defaultAuth:
  users:
    - username: admin
      password: admin
      roles:
        - admin
      orgClaimName: ACME
      organizationIdentifier: ACME
